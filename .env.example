# === AI 后端（MiniMax，OpenAI 兼容） ===
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL_ID=MiniMax-M2

# === 数据库（线程/消息/附件持久化 + 用户/计费） ===
DATABASE_URL=postgres://user:password@localhost:5432/thread-chat

# === 用户系统（better-auth，邮箱注册登录） ===
# BETTER_AUTH_SECRET：任意高熵随机串（如 openssl rand -base64 32）。
# BETTER_AUTH_URL：站点对外地址，本地为 http://localhost:3000。
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# === Cloudflare AI 网关（DeepSeek / OpenAI 等经网关转发并统计用量） ===
# 配置后 DeepSeek / OpenAI 模型走 https://gateway.ai.cloudflare.com/v1/{账号ID}/{网关名}/compat
# 未配置则回退各供应商直连；MiniMax 不在 CF 支持列表中，始终直连。
CF_AI_GATEWAY_ACCOUNT_ID=
CF_AI_GATEWAY_ID=
# 仅当网关开启了 Authenticated Gateway 时需要（会作为 cf-aig-authorization 头）。
CF_AI_GATEWAY_TOKEN=

# === 经网关接入的大模型供应商 Key（按需填写，对应 constants/model.ts 的模型） ===
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# === Cloudflare R2（附件存储，ChatPDF 依赖） ===
# 未配置时聊天主流程不受影响，仅附件上传返回 503。
# 桶需配置 CORS：AllowedMethods 含 PUT，AllowedHeaders 显式含 Content-Type（见 README）。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=thread-chat-attachments

# === Embeddings（可选，RAG 检索用） ===
# MiniMax 国际站无 embeddings，向量化交给任意 OpenAI 兼容服务。
# 不配置则超大 PDF 走全文截断注入；配置后超出上下文预算的文档改走向量检索。
# 注意：更换不同维度的模型需同步修改 constants/rag.ts 的 EMBEDDING_DIMENSIONS 并重建迁移。
# 数据库需启用 pgvector 扩展（迁移会自动 CREATE EXTENSION vector）。
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# === Web 搜索（可选，深度研究用） ===
# 默认 Tavily（/search 直接返回正文快照，/extract 深读整页）。
# 未配置 SEARCH_API_KEY 时深度研究开关会提示不可用，普通对话不受影响。
SEARCH_API_KEY=
SEARCH_BASE_URL=https://api.tavily.com
