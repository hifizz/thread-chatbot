# === AI 后端（MiniMax，OpenAI 兼容） ===
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL_ID=MiniMax-M2

# === 数据库（线程/消息/附件持久化 + 用户/计费） ===
DATABASE_URL=postgres://user:password@localhost:5432/thread-chat

# === 用户系统（better-auth，邮箱注册登录） ===
# BETTER_AUTH_SECRET：任意高熵随机串（如 openssl rand -base64 32）。
# BETTER_AUTH_URL：站点对外地址，本地为 http://localhost:3000。
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# === 邮件服务（Resend）：邮箱验证 / 找回密码 ===
# 配了 RESEND_API_KEY 才会强制邮箱验证（并把初始额度改到「验证后」发放，防白嫖）；
# 未配置则降级为「注册即用」（仅开发用）。EMAIL_FROM 需用 Resend 已验证的域名。
RESEND_API_KEY=
EMAIL_FROM=Thread Chat <noreply@yourdomain.com>
# 可选：覆盖 Resend 端点（自建/测试）。
# RESEND_BASE_URL=

# === 注册人机验证（Cloudflare Turnstile，可选，防批量注册薅额度） ===
# 配了 secret 才启用；同时把站点 key 配给前端组件。默认拦截注册/登录接口。
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# === Cloudflare AI 网关（DeepSeek / OpenAI 等经网关转发并统计用量） ===
# 配置后 DeepSeek / OpenAI 模型走 https://gateway.ai.cloudflare.com/v1/{账号ID}/{网关名}/compat
# 未配置则回退各供应商直连；MiniMax 不在 CF 支持列表中，始终直连。
CF_AI_GATEWAY_ACCOUNT_ID=
CF_AI_GATEWAY_ID=
# 仅当网关开启了 Authenticated Gateway 时需要（会作为 cf-aig-authorization 头）。
CF_AI_GATEWAY_TOKEN=

# === 经网关接入的大模型供应商 Key（按需填写，对应 constants/model.ts 的模型） ===
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# === Vercel AI 网关（可选，优先于 CF/直连；用于「真实成本对账」） ===
# 配置后非 MiniMax 模型经 Vercel 网关，响应带 generationId，可事后拉取真实成本(USD)对账。
# 网关自带各供应商凭据，无需再单独配 DEEPSEEK/OPENAI key。
AI_GATEWAY_API_KEY=
# 可选：覆盖网关地址（自建/区域代理/测试），默认官方 https://ai-gateway.vercel.sh
AI_GATEWAY_BASE_URL=

# === 计费：汇率与对账 ===
# 供应商多以美元计价，额度以人民币「微元」结算，按此汇率折算（建议留缓冲，宁高勿低）。
USD_TO_CNY=7.3
# 真实成本对账端点 /api/billing/reconcile 的调用密钥（定时任务用 Authorization: Bearer <该值>）。
CRON_SECRET=

# === Creem 支付（充值 / 订阅） ===
# CREEM_API_KEY：Creem 后台的 API Key（发起 checkout 用）。
# CREEM_API_URL：正式 https://api.creem.io/v1（默认）；测试用 https://test-api.creem.io/v1。
# CREEM_WEBHOOK_SECRET：Creem 后台 Developers>Webhook 的密钥，用于校验 webhook 签名。
CREEM_API_KEY=
CREEM_API_URL=https://api.creem.io/v1
CREEM_WEBHOOK_SECRET=
# 各充值包对应的 Creem 产品 id（在 Creem 后台创建产品后填入；定价需与 constants/creem.ts 展示价一致）。
CREEM_PRODUCT_TOPUP_20=
CREEM_PRODUCT_TOPUP_50=
CREEM_PRODUCT_TOPUP_100=
# 可选：订阅产品 id → 套餐名映射，形如 "prod_a:Pro,prod_b:Team"（仅用于账户页展示订阅名）。
CREEM_SUBSCRIPTION_PRODUCTS=

# === Cloudflare R2（附件存储，ChatPDF 依赖） ===
# 未配置时聊天主流程不受影响，仅附件上传返回 503。
# 桶需配置 CORS：AllowedMethods 含 PUT，AllowedHeaders 显式含 Content-Type（见 README）。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=thread-chat-attachments

# === Embeddings（可选，RAG 检索用） ===
# MiniMax 国际站无 embeddings，向量化交给任意 OpenAI 兼容服务。
# 不配置则超大 PDF 走全文截断注入；配置后超出上下文预算的文档改走向量检索。
# 注意：更换不同维度的模型需同步修改 constants/rag.ts 的 EMBEDDING_DIMENSIONS 并重建迁移。
# 数据库需启用 pgvector 扩展（迁移会自动 CREATE EXTENSION vector）。
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# === Web 搜索（可选，深度研究用） ===
# 默认 Tavily（/search 直接返回正文快照，/extract 深读整页）。
# 未配置 SEARCH_API_KEY 时深度研究开关会提示不可用，普通对话不受影响。
SEARCH_API_KEY=
SEARCH_BASE_URL=https://api.tavily.com
